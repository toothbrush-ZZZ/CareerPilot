# ==============================================================
# CareerPilot — Environment Variables Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==============================================================

# LLM Providers (API Keys)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Authentication Security (Random hex string)
JWT_SECRET=

# Database Connection URI (e.g. sqlite+aiosqlite:///./data/careerpilot.db)
DATABASE_URL=

# Backend API Endpoint URL (e.g. http://localhost:8000)
NEXT_PUBLIC_API_URL=

# Allowed CORS origins (e.g. http://localhost:3000,http://127.0.0.1:3000)
CORS_ORIGINS=
