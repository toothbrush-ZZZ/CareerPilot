# ==============================================================
# CareerPilot — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==============================================================

# Required Keys (See API.md for configuration manual)
GROQ_API_KEY=
JWT_SECRET=

# ==============================================================
# DATABASE — REQUIRED
# SQLite path relative to the backend working directory.
# Default works out of the box with docker-compose.
# ==============================================================
DATABASE_URL=sqlite+aiosqlite:///./data/careerpilot.db

# ==============================================================
# FRONTEND — REQUIRED
# URL the browser uses to reach the backend API.
# For local dev this is always http://localhost:8000.
# For production, set this to your deployed backend URL.
# ==============================================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# ==============================================================
# CORS — REQUIRED
# Comma-separated list of allowed frontend origins.
# Add your production frontend URL here when deploying.
# ==============================================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==============================================================
# OPTIONAL / FUTURE
# Uncomment and fill in only when needed.
# ==============================================================

# Gemini API (not used in current implementation)
# GEMINI_API_KEY=your_gemini_api_key_here