# --- Supabase Auth (Local demo or Hosted) ---
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# --- AI Models ---
# Get keys at console.groq.com and aistudio.google.com
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key

# --- Job Search APIs ---
# Get keys at developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# --- Infrastructure ---
# Default for Docker Compose
POSTGRES_URL=postgresql://cpuser:cppass@db:5432/careerpilot
REDIS_URL=redis://redis:6379
EMBED_URL=http://embed:8001

# --- AI Services (Ollama - Required) ---
# Local Ollama instance for AI inference
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# --- Security ---
# Found in Supabase Settings -> API -> JWT Settings
JWT_SECRET=your_jwt_secret