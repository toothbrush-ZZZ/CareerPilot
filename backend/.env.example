# CareerPilot Backend Environment Variables Example

# Primary AI Model API Key (Groq)
GROQ_API_KEY="your_groq_api_key_here"

# Secondary Fallback AI Model API Key (Google Gemini)
GEMINI_API_KEY="your_gemini_api_key_here"

# Ultimate Fallback AI Model API Key (OpenRouter)
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Database Configuration (Optional, defaults to local SQLite if omitted)
# DATABASE_URL="sqlite+aiosqlite:///./data/careerpilot.db"
